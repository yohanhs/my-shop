{
  "name": "my-shop",
  "version": "1.0.0",
  "description": "Gestor de Contabilidad para Tienda - Offline First",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run start:wait\"",
    "start:wait": "npx wait-on http://localhost:5173 && electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "prisma:generate": "prisma generate --schema=src/main/db/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/main/db/schema.prisma",
    "seed": "ts-node src/main/db/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron": "^41.2.0",
    "lucide-react": "^1.7.0",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "yup": "^1.7.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.4"
  }
}
